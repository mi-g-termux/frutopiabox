{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/firebase-config.json", "destination": "/api/firebase-config" },
    { "source": "/api/bkash/:action",      "destination": "/api/bkash?action=:action" },
    { "source": "/api/nagad/:action",      "destination": "/api/nagad?action=:action" },
    { "source": "/api/paypal/:action",     "destination": "/api/paypal?action=:action" },
    { "source": "/api/razorpay/:action",   "destination": "/api/razorpay?action=:action" },
    { "source": "/api/sslcommerz/:action", "destination": "/api/sslcommerz?action=:action" },
    { "source": "/api/stripe/:action",     "destination": "/api/stripe?action=:action" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/|.*\\..+$).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
